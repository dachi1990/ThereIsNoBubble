{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/metrics",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/data-health",
      "schedule": "45 */6 * * *"
    }
  ]
}
